<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.nut.dao.AccessTokenMapper" >
  <resultMap id="BaseResultMap" type="com.nut.entity.AccessToken" >
    <constructor >
      <arg column="access_token" jdbcType="VARCHAR" javaType="java.lang.String" />
    </constructor>
  </resultMap>
  <insert id="insert" parameterType="com.nut.entity.AccessToken" >
    insert into wx_access_token (access_token)
    values (#{accessToken,jdbcType=VARCHAR})
  </insert>
  <insert id="insertSelective" parameterType="com.nut.entity.AccessToken" >
    insert into wx_access_token
    <trim prefix="(" suffix=")" suffixOverrides="," >
      <if test="accessToken != null" >
        access_token,
      </if>
    </trim>
    <trim prefix="values (" suffix=")" suffixOverrides="," >
      <if test="accessToken != null" >
        #{accessToken,jdbcType=VARCHAR},
      </if>
    </trim>
  </insert>
</mapper>